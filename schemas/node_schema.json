{
  "type": "object",
  "required": ["node_slug", "action", "changes"],
  "properties": {
    "node_slug": { "type": "string" },
    "action": { "enum": ["update", "create", "archive"] },
    "clarification_needed": { "type": "boolean" },
    "clarification_question": { "type": ["string", "null"] },
    "changes": {
      "type": "object",
      "properties": {
        "title":              { "type": ["string", "null"] },
        "slug":               { "type": ["string", "null"] },
        "status":             { "enum": ["idea", "early_mvp", "mvp", "live", "shelved", null] },
        "tags":               { "type": ["array", "null"] },
        "summary":            { "type": ["string", "null"] },
        "kind":              { "enum": ["component", "system", "framework", null] },
        "stage":             { "enum": ["idea", "building", "working", "maturing", null] },
        "part_of":           { "type": ["string", "null"] },
        "feeds":             { "type": ["array", "null"], "items": { "type": "string" } },
        "depends_on":        { "type": ["array", "null"], "items": { "type": "string" } },
        "primary_audience":   { "type": ["string", "null"] },
        "secondary_audience": { "type": ["string", "null"] },
        "risks": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "required": ["category", "description", "score"],
            "properties": {
              "category":    { "enum": ["technical", "market", "legal", "ops", "competition", "positioning", "adoption"] },
              "description": { "type": "string" },
              "score":       { "type": "number", "minimum": 1, "maximum": 25 },
              "probability": { "type": "number", "minimum": 1, "maximum": 5 },
              "impact":      { "type": "number", "minimum": 1, "maximum": 5 },
              "mitigation":  { "type": ["string", "null"] }
            }
          }
        },
        "notes_append": { "type": ["string", "null"] },
        "updated_at":   { "type": "string" }
      }
    }
  }
}
