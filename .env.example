# Required for AI analysis: `cns analyze` (CNS Analyst) and devlog AI-sammanfattningar
ANTHROPIC_API_KEY=your_key_here

# GitHub Projects-synk (`cns project sync`, epic #13)
# Org som äger projektet "Backlog" — skild från GITHUB_REPO-ägaren (repot kan ligga
# på ett user-konto medan projektet är org-ägt). Krävs av sync + gh_projects-verktygen.
CNS_PROJECT_OWNER=Cortxt-io
# Token för sync behöver `project`-scope: sätt CNS_GITHUB_TOKEN, eller kör lokalt med
# `gh auth refresh -s project` (scriptet faller tillbaka på `gh auth token`).

# MCP OAuth — persistent token storage (production only)
# Without these, tokens are stored in memory and die on worker restart.
# REDIS_URL=redis://localhost:6379
# JWT_SIGNING_KEY=<generate with: python -c "import secrets; print(secrets.token_urlsafe(48))">
# STORAGE_ENCRYPTION_KEY=<generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
